{
	"name": "df_bronze_ventas_consolidadas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_sucursal_lpz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ventas_sucursal_scz_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "NombresEstandarizadosLPZ"
				},
				{
					"name": "NombresEstandarizadosSCZ"
				},
				{
					"name": "NombresEstandarizadosOL"
				},
				{
					"name": "CanalLPZ"
				},
				{
					"name": "CanalSCZ"
				},
				{
					"name": "CanalOnline"
				},
				{
					"name": "LPZunionSCZ"
				},
				{
					"name": "LPZunionSCZunionOnline"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Venta as string,",
				"          Fecha_Venta as string,",
				"          Producto as string,",
				"          Cant as string,",
				"          PrecioUnit as string,",
				"          Sucursal as string,",
				"          Vendedor as string,",
				"          NombreCliente as string,",
				"          EmailCliente as string,",
				"          MetodoPago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1 select(mapColumn(",
				"          {id_transaccion_origen } = ID_Venta,",
				"          {fecha_venta } = Fecha_Venta,",
				"          {nombre_producto_original } = Producto,",
				"          {cantidad } = Cant,",
				"          {precio_unitario } = PrecioUnit,",
				"          {canal_venta } = Sucursal,",
				"          {cliente_nombre } = NombreCliente,",
				"          {metodo_pago } = MetodoPago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> NombresEstandarizadosLPZ",
				"source2 select(mapColumn(",
				"          {id_transaccion_origen } = id_venta,",
				"          {fecha_venta } = fecha,",
				"          {nombre_producto_original } = producto,",
				"          {cantidad } = cantidad,",
				"          {precio_unitario } = precio_unitario,",
				"          {canal_venta } = sucursal,",
				"          {cliente_nombre } = cliente_nombre,",
				"          {metodo_pago } = metodo_pago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> NombresEstandarizadosSCZ",
				"source3 select(mapColumn(",
				"          {id_transaccion_origen } = order_id,",
				"          {fecha_venta } = timestamp,",
				"          {nombre_producto_original } = product,",
				"          {cantidad } = qty,",
				"          {precio_unitario } = unit_price,",
				"          {cliente_nombre } = {customer/name},",
				"          {metodo_pago } = payment_method,",
				"          {costo_envio } = shipping_cost,",
				"          {canal_venta } = channel",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> NombresEstandarizadosOL",
				"NombresEstandarizadosLPZ derive({canal_venta } = \"LPZ\") ~> CanalLPZ",
				"NombresEstandarizadosSCZ derive({canal_venta } = \"SCZ\") ~> CanalSCZ",
				"NombresEstandarizadosOL derive({canal_venta } = \"Online\") ~> CanalOnline",
				"CanalLPZ, CanalSCZ union(byName: true)~> LPZunionSCZ",
				"LPZunionSCZ, CanalOnline union(byName: true)~> LPZunionSCZunionOnline"
			]
		}
	}
}