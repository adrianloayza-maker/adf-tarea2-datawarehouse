{
	"name": "df_bronze_ventas_consolidadas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ventas_sucursal_lpz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ventas_sucursal_scz_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "ventas_online_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "silver_inventario",
						"type": "DatasetReference"
					},
					"name": "source4"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_ventas_consolidadas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "NombresEstandarizadosLPZ"
				},
				{
					"name": "NombresEstandarizadosSCZ"
				},
				{
					"name": "NombresEstandarizadosOL"
				},
				{
					"name": "CanalLPZ"
				},
				{
					"name": "CanalSCZ"
				},
				{
					"name": "CanalOnline"
				},
				{
					"name": "LPZunionSCZ"
				},
				{
					"name": "LPZunionSCZunionOnline"
				},
				{
					"name": "Limpieza"
				},
				{
					"name": "SolucionValoresNulos"
				},
				{
					"name": "CalcMontoTotal"
				},
				{
					"name": "BuscarCodProducto"
				},
				{
					"name": "SeleccionColumnas"
				},
				{
					"name": "CodigosNulos"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Venta as string,",
				"          Fecha_Venta as string,",
				"          Producto as string,",
				"          Cant as string,",
				"          PrecioUnit as string,",
				"          Sucursal as string,",
				"          Vendedor as string,",
				"          NombreCliente as string,",
				"          EmailCliente as string,",
				"          MetodoPago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          id_venta as string,",
				"          fecha as string,",
				"          producto as string,",
				"          cantidad as string,",
				"          precio_unitario as string,",
				"          sucursal as string,",
				"          vendedor as string,",
				"          cliente_nombre as string,",
				"          cliente_email as string,",
				"          metodo_pago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          order_id as string,",
				"          timestamp as string,",
				"          product as string,",
				"          qty as string,",
				"          unit_price as string,",
				"          {customer/name} as string,",
				"          {customer/email} as string,",
				"          {customer/city} as string,",
				"          payment_method as string,",
				"          status as string,",
				"          shipping_cost as string,",
				"          channel as string,",
				"          customer as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          codigo_producto as string,",
				"          nombre_producto as string,",
				"          categoria as string,",
				"          precio_venta as decimal(18,2),",
				"          costo_adquisicion as decimal(18,2),",
				"          stock_actual as integer,",
				"          sucursal as string,",
				"          proveedor as string,",
				"          ultima_reposicion as date,",
				"          activo as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source4",
				"source1 select(mapColumn(",
				"          {id_transaccion_origen } = ID_Venta,",
				"          {fecha_venta } = Fecha_Venta,",
				"          {nombre_producto_original } = Producto,",
				"          {cantidad } = Cant,",
				"          {precio_unitario } = PrecioUnit,",
				"          {canal_venta } = Sucursal,",
				"          {cliente_nombre } = NombreCliente,",
				"          {metodo_pago } = MetodoPago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> NombresEstandarizadosLPZ",
				"source2 select(mapColumn(",
				"          {id_transaccion_origen } = id_venta,",
				"          {fecha_venta } = fecha,",
				"          {nombre_producto_original } = producto,",
				"          {cantidad } = cantidad,",
				"          {precio_unitario } = precio_unitario,",
				"          {canal_venta } = sucursal,",
				"          {cliente_nombre } = cliente_nombre,",
				"          {metodo_pago } = metodo_pago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> NombresEstandarizadosSCZ",
				"source3 select(mapColumn(",
				"          {id_transaccion_origen } = order_id,",
				"          {fecha_venta } = timestamp,",
				"          {nombre_producto_original } = product,",
				"          {cantidad } = qty,",
				"          {precio_unitario } = unit_price,",
				"          {cliente_nombre } = {customer/name},",
				"          {metodo_pago } = payment_method,",
				"          {costo_envio } = shipping_cost,",
				"          {canal_venta } = channel",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> NombresEstandarizadosOL",
				"NombresEstandarizadosLPZ derive({canal_venta } = \"LPZ\") ~> CanalLPZ",
				"NombresEstandarizadosSCZ derive({canal_venta } = \"SCZ\") ~> CanalSCZ",
				"NombresEstandarizadosOL derive({canal_venta } = \"Online\") ~> CanalOnline",
				"CanalLPZ, CanalSCZ union(byName: true)~> LPZunionSCZ",
				"LPZunionSCZ, CanalOnline union(byName: true)~> LPZunionSCZunionOnline",
				"LPZunionSCZunionOnline derive({fecha_venta } = iif(\r",
				"    isDate({fecha_venta }, 'yyyy-MM-dd'),\r",
				"    toDate({fecha_venta }, 'yyyy-MM-dd'),\r",
				"\r",
				"    iif(\r",
				"        isDate({fecha_venta }, 'MM-dd-yyyy'),\r",
				"        toDate({fecha_venta }, 'MM-dd-yyyy'),\r",
				"\r",
				"        iif(\r",
				"            isDate({fecha_venta }, 'dd/MM/yyyy'),\r",
				"            toDate({fecha_venta }, 'dd/MM/yyyy'),\r",
				"\r",
				"            iif(\r",
				"                isDate({fecha_venta }, 'yyyy/MM/dd'),\r",
				"                toDate({fecha_venta }, 'yyyy/MM/dd'),\r",
				"\r",
				"                iif(\r",
				"                    isDate({fecha_venta }, 'dd-MMM-yyyy'),\r",
				"                    toDate({fecha_venta }, 'dd-MMM-yyyy'),\r",
				"\r",
				"                    iif(\r",
				"                        isDate({fecha_venta }, 'MMMM dd, yyyy'),\r",
				"                        toDate({fecha_venta }, 'MMMM dd, yyyy'),\r",
				"\r",
				"                        toDate('1900-01-01')\r",
				"                    )\r",
				"                )\r",
				"            )\r",
				"        )\r",
				"    )\r",
				")\r",
				",",
				"          {nombre_producto_original } = initCap(regexReplace(trim({nombre_producto_original }), '\\\\s+', ' ')),",
				"          {precio_unitario } = round(\r",
				"    toDecimal(\r",
				"        regexReplace(\r",
				"            lower(toString({precio_unitario })),\r",
				"            '[^0-9]',\r",
				"            ''\r",
				"        )\r",
				"    ) / 100,\r",
				"2),",
				"          {cantidad } = toInteger({cantidad })) ~> Limpieza",
				"Limpieza derive({precio_unitario } = toDecimal(iifNull({precio_unitario }, 0, {precio_unitario })),",
				"          {costo_envio } = iifNull({costo_envio }, \"0.0\", {costo_envio }) ,",
				"          {cantidad } = iifNull({cantidad }, 0, {cantidad }) ) ~> SolucionValoresNulos",
				"SolucionValoresNulos derive({monto_total } = toDecimal(\r",
				"    round(\r",
				"        toDecimal({precio_unitario }) * toDecimal({cantidad }),\r",
				"    2)\r",
				")) ~> CalcMontoTotal",
				"CalcMontoTotal, source4 lookup({nombre_producto_original } == nombre_producto,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> BuscarCodProducto",
				"BuscarCodProducto select(mapColumn(",
				"          {id_transaccion_origen },",
				"          {fecha_venta },",
				"          {nombre_producto_original },",
				"          {cantidad },",
				"          {precio_unitario },",
				"          {canal_venta },",
				"          {cliente_nombre },",
				"          {metodo_pago },",
				"          {costo_envio },",
				"          {monto_total },",
				"          codigo_producto",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SeleccionColumnas",
				"SeleccionColumnas filter(!isNull(codigo_producto)) ~> CodigosNulos",
				"CodigosNulos sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_transaccion_origen as string,",
				"          fecha_venta as timestamp,",
				"          codigo_producto as string,",
				"          nombre_producto_original as string,",
				"          cantidad as integer,",
				"          precio_unitario as decimal(18,2),",
				"          monto_total as decimal(18,2),",
				"          canal_venta as string,",
				"          cliente_nombre as string,",
				"          metodo_pago as string,",
				"          costo_envio as decimal(18,2),",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_transaccion_origen = {id_transaccion_origen },",
				"          fecha_venta = {fecha_venta },",
				"          codigo_producto,",
				"          nombre_producto_original = {nombre_producto_original },",
				"          cantidad = {cantidad },",
				"          precio_unitario = {precio_unitario },",
				"          monto_total = {monto_total },",
				"          canal_venta = {canal_venta },",
				"          cliente_nombre = {cliente_nombre },",
				"          metodo_pago = {metodo_pago },",
				"          costo_envio = {costo_envio }",
				"     )) ~> sink1"
			]
		}
	}
}